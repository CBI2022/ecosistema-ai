# Supabase (obtener en Supabase Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# Site URL (requerido para OAuth redirects y otras URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenRouter (AI: generación de descripciones de propiedades)
OPENROUTER_API_KEY=sk-or-xxx

# Web Push (notificaciones PWA)
# Generar con: node -e "console.log(require('web-push').generateVAPIDKeys())"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=B...
VAPID_PRIVATE_KEY=xxx
VAPID_EMAIL=mailto:admin@tu-dominio.com

# Opus Clip webhook secret (opcional, valida firma)
OPUS_WEBHOOK_SECRET=xxx

# Google OAuth (compartido entre Google Calendar y YouTube Data API v3)
# Crear en https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client ID
# Habilitar APIs: "Google Calendar API" y "YouTube Data API v3"
# Redirect URIs autorizados:
#   http://localhost:3000/api/google/callback
#   http://localhost:3000/api/youtube/callback
#   https://app.costablancainvestments.com/api/google/callback
#   https://app.costablancainvestments.com/api/youtube/callback
GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=xxx

# YouTube API Key (opcional — solo para lecturas públicas: search, video stats sin OAuth)
# Crear en https://console.cloud.google.com/apis/credentials → API key (con YouTube Data API v3 habilitada)
YOUTUBE_API_KEY=

# YouTube webhook (PubSubHubbub para recibir nuevos videos del canal)
YOUTUBE_WEBHOOK_SECRET=
